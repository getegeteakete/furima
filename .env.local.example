# =============================================
# Supabase 接続情報
# Supabase ダッシュボード → Project Settings → API からコピー
# このファイルを .env.local にコピーして値を埋める
# =============================================

# プロジェクトURL（例: https://abcdefgh.supabase.co）
NEXT_PUBLIC_SUPABASE_URL=

# anon public key（クライアント公開可・RLSで保護）
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# service_role key（サーバー専用・絶対にクライアントへ出さない / Cron・管理処理用）
SUPABASE_SERVICE_ROLE_KEY=

# Cron認証用シークレット（Vercel Cron が Bearer で付与）。任意の長いランダム文字列。
# Vercel: Settings → Environment Variables に同名で登録すること。
CRON_SECRET=
